# ------------------------------
# OS / Editor
# ------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ------------------------------
# Local env / secrets
# ------------------------------
.env
.env.*
!.env.example
config/.env.network
config/.env.*
