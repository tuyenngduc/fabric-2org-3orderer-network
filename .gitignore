# ------------------------------
# Hyperledger Fabric generated artifacts
# ------------------------------
# Crypto material and MSP/TLS identities (do not commit)
organizations/**
!organizations/.gitkeep

# Channel artifacts generated by configtxgen / scripts
channel-artifacts/*.block
channel-artifacts/*.tx
channel-artifacts/*.pb
channel-artifacts/*.json
channel-artifacts/anchor-updates/

# Runtime backups / logs
backups/
logs/
*.log

# Optional local helper outputs
*.tar.gz
*.tgz
.tools/

# Keep production network repo independent from sample assets
/fabric-samples/

